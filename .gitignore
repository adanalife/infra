# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Terraform
.terraform
*.plan
*.tfstate.backup
*.auto.tfvars

# k8s secrets
k8s/**/credentials
k8s/**/secret-access-key
k8s/**/secret.env

# Local Postgres dumps (tripbot:stage:db:backup writes here by default)
backups/

# Per-machine local overrides — values.local.yml (helm) and *.local.yaml
# (kustomize manifests with host-specific addresses/paths), generated or
# hand-edited per host.
k8s/**/values.local.yml
k8s/**/*.local.yaml
