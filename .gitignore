# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Terraform stuff
.terraform
*.plan
*.tfstate.backup
# auto-loaded local-only var overrides (e.g. home IP, regenerated
# from `curl ifconfig.me` by the tf-cloudflare Taskfile target).
*.auto.tfvars

# k8s secrets
k8s/**/credentials
k8s/**/secret-access-key
k8s/**/secret.env

# Per-machine helm overrides written by `task k8s:bootstrap-secrets` —
# notably external-dns/stage-1/values.local.yml, which sets
# `extraArgs: [--default-targets=<host public IP>]` from `curl ifconfig.me`.
# Keeps machine-specific values out of git so a stage-1 apply works on
# any host without manifest churn.
k8s/**/values.local.yml
