{
  "title": "02 — Stream Health: vlc-server ↔ OBS",
  "uid": "stream-health",
  "tags": ["tripbot", "vlc-server", "obs", "stream"],
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "deployment_environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
        "query": "label_values(target_info{service_name=~\"tripbot|vlc-server\"}, deployment_environment)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Stream",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(obs_streaming_active{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DARK", "color": "red" }, "1": { "text": "LIVE", "color": "green" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "VLC FPS (libvlc)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(vlc_player_displayed_fps{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"})" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1 }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "OBS FPS (encoder)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(obs_active_fps{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1 }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Output bitrate",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "8 * rate(obs_stream_output_bytes{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[1m])" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bps" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Congestion",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(obs_stream_output_congestion{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.25 },
            { "color": "red", "value": 0.5 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "VLC frame health (displayed vs lost)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "rate(vlc_player_displayed_pictures{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "displayed/s" },
        { "refId": "B", "expr": "rate(vlc_player_lost_pictures{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "lost/s" },
        { "refId": "C", "expr": "rate(vlc_player_demux_corrupted{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "demux corrupted/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "lost/s" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "demux corrupted/s" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "OBS skipped frames",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "rate(obs_render_skipped_frames{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "render thread" },
        { "refId": "B", "expr": "rate(obs_output_skipped_frames{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "output thread" },
        { "refId": "C", "expr": "rate(obs_stream_output_skipped_frames{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "stream output" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Output bitrate",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "8 * rate(obs_stream_output_bytes{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "stream output" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Congestion & reconnect state",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "max(obs_stream_output_congestion{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "congestion" },
        { "refId": "B", "expr": "max(obs_stream_output_reconnecting{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "reconnecting" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "VLC input/demux bitrate (libvlc-native units)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "max(vlc_player_input_bitrate{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "input" },
        { "refId": "B", "expr": "max(vlc_player_demux_bitrate{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "demux" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "OBS CPU & memory",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "max(obs_cpu_usage_percent{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "cpu %" },
        { "refId": "B", "expr": "max(obs_memory_usage_mb{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "memory (MB)" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "OBS avg frame render time",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "max(obs_average_frame_render_time_ms{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "ms/frame" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 40,
      "type": "text",
      "title": "Live stream (adanalife_)",
      "gridPos": { "x": 0, "y": 27, "w": 16, "h": 9 },
      "options": {
        "mode": "html",
        "content": "<iframe src=\"https://player.twitch.tv/?channel=adanalife_&parent=adanalife.grafana.net&muted=true\" width=\"100%\" height=\"100%\" frameborder=\"0\" allowfullscreen=\"true\"></iframe>"
      }
    }
  ]
}
