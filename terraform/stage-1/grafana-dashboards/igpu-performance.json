{
  "uid": "9VxbZDPnk",
  "title": "05 — iGPU Performance",
  "tags": ["gpu", "intel", "xpumanager", "performance"],
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "Node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "__DS_PROMETHEUS__"
        },
        "query": {
          "query": "label_values(xpum_frequency_mhz, node)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "iGPU — $Node (Intel Iris Xe)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Render engine",
      "description": "Composite/3D engine utilization. OBS scene composition lands here.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(xpum_per_engine_ratio{node=\"$Node\", type=\"render\"})"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Decode engine",
      "description": "Video decode (VAAPI). VLC hardware-decoding the RTSP feed lands here.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(xpum_per_engine_ratio{node=\"$Node\", type=\"decoder\"})"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Encode engine",
      "description": "Video encode (VAAPI). OBS streaming encode lands here.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(xpum_per_engine_ratio{node=\"$Node\", type=\"encoder\"})"
        }
      ]
    },
    {
      "type": "stat",
      "title": "GPU frequency",
      "description": "Actual iGPU clock. Floor ~300 MHz, boosts under load.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "hertz",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(xpum_frequency_mhz{node=\"$Node\", type=\"actual\"}) * 1000000"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Engine utilization by type",
      "description": "Per-engine-type utilization on the Iris Xe. render = composite/3D (OBS), decoder/encoder = VAAPI media (VLC decode, OBS encode), copy = blitter, media_enhancement = post-processing. Averaged across engine instances of each type.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (type) (xpum_per_engine_ratio{node=\"$Node\"})",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GPU frequency",
      "description": "Actual vs requested iGPU clock.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "hertz",
          "decimals": 0,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "xpum_frequency_mhz{node=\"$Node\", type=\"actual\"} * 1000000",
          "legendFormat": "actual"
        },
        {
          "refId": "B",
          "expr": "xpum_frequency_mhz{node=\"$Node\", type=\"request\"} * 1000000",
          "legendFormat": "requested"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Per-engine-instance utilization",
      "description": "Each physical engine instance broken out (the Iris Xe has multiple decode/encode engines). Useful for spotting whether work is balanced across instances.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 1,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "xpum_per_engine_ratio{node=\"$Node\"}",
          "legendFormat": "{{type}} #{{engine_id}}"
        }
      ]
    }
  ]
}
