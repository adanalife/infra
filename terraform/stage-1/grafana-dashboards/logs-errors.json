{
  "title": "06 — Logs & Errors",
  "uid": "logs-errors",
  "tags": ["tripbot", "vlc-server", "logs"],
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "deployment_environment",
        "type": "query",
        "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
        "query": "label_values({service_name=~\".+\"}, deployment_environment)",
        "current": { "text": "prod-1", "value": "prod-1" },
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
        "query": "label_values({deployment_environment=~\".+\"}, service_name)",
        "current": { "text": "All", "value": ".+" },
        "includeAll": true,
        "allValue": ".+",
        "multi": false,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Free-text search",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Errors (range)",
      "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({service_name=~\"$service\", deployment_environment=~\"$deployment_environment\"} | detected_level=\"error\" [$__range]))" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 100 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Warnings (range)",
      "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({service_name=~\"$service\", deployment_environment=~\"$deployment_environment\"} | detected_level=\"warn\" [$__range]))" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 500 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total log lines (range)",
      "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "targets": [
        { "refId": "A", "expr": "sum(count_over_time({service_name=~\"$service\", deployment_environment=~\"$deployment_environment\"}[$__range]))" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Log volume by severity",
      "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (detected_level, deployment_environment) (rate({service_name=~\"$service\", deployment_environment=~\"$deployment_environment\"}[$__auto]))", "legendFormat": "{{detected_level}} [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "logs/s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 30, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Errors & warnings",
      "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 14 },
      "targets": [
        { "refId": "A", "expr": "{service_name=~\"$service\", deployment_environment=~\"$deployment_environment\"} | detected_level=~\"error|warn\" |~ \"$search\"" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "All logs (matching search)",
      "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 12 },
      "targets": [
        { "refId": "A", "expr": "{service_name=~\"$service\", deployment_environment=~\"$deployment_environment\"} |~ \"$search\"" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    },
    {
      "id": 7,
      "type": "text",
      "title": "Sentry throttle",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "Counter emitted by `pkg/errors.throttle` in [tripbot#578](https://github.com/adanalife/tripbot/pull/578). Every event slated for Sentry passes through a BeforeSend hook; suppressed events are counted here labeled by **reason**: `cooldown` (same fingerprint within 15min), `cap` (>20 events in the rolling hour), `disabled` (dev/testing environments where Sentry capture is intentionally off). Suppressed events still reach Loki — Sentry just gets a deduplicated sample to preserve free-tier headroom (5k events/month). High `cap` rate means something is flapping; high `cooldown` is the throttle working as intended."
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Sentry drops (range)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 42, "w": 6, "h": 6 },
      "targets": [
        { "refId": "A", "expr": "sum by (reason, deployment_environment) (increase(sentry_events_dropped_total{deployment_environment=~\"$deployment_environment\"}[$__range]))", "legendFormat": "{{reason}} [{{deployment_environment}}]" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 500 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Sentry drops by reason",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 42, "w": 18, "h": 6 },
      "targets": [
        { "refId": "A", "expr": "sum by (reason, deployment_environment) (rate(sentry_events_dropped_total{deployment_environment=~\"$deployment_environment\"}[$__rate_interval]))", "legendFormat": "{{reason}} [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 30, "stacking": { "mode": "normal" } } }, "overrides": [] }
    }
  ]
}
