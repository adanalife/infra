{
  "title": "vlc-server — Service Health",
  "uid": "vlc-server-service-health",
  "tags": ["tripbot", "vlc-server", "service-health"],
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "deployment_environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
        "query": "label_values(target_info{service_name=\"vlc-server\"}, deployment_environment)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Data fresh (last 1m)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "(time() - max(timestamp(last_over_time(http_server_request_duration_seconds_count{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[10m])))) < bool 60" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "mappings": [
            { "type": "value", "options": { "0": { "text": "STALE", "color": "red" }, "1": { "text": "FRESH", "color": "green" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests / sec",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[5m]))" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error rate (5xx)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(http_server_request_duration_seconds_count{service_name=\"vlc-server\", http_response_status_code=~\"5..\", deployment_environment=~\"$deployment_environment\"}[5m])) or vector(0)) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[5m])), 0.001)"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 latency",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP server latency (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests by status code",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_seconds_count{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]))", "legendFormat": "{{http_response_status_code}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 30, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Response size p95",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_response_body_size_bytes_bucket{service_name=\"vlc-server\"}[$__rate_interval])))", "legendFormat": "p95 response" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Requests by method",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (http_request_method) (rate(http_server_request_duration_seconds_count{service_name=\"vlc-server\"}[$__rate_interval]))", "legendFormat": "{{http_request_method}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 30, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Recent errors & warnings",
      "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 10 },
      "targets": [
        { "refId": "A", "expr": "{service_name=\"vlc-server\"} | severity_text=~\"ERROR|WARN\"" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
