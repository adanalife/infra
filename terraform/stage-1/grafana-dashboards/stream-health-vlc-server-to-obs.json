{
  "title": "01 — Stream Health: vlc-server ↔ OBS",
  "uid": "stream-health",
  "tags": ["tripbot", "vlc-server", "obs", "stream"],
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "platform",
        "label": "Platform",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
        "query": "label_values(target_info{service_namespace=\"tripbot\"}, service_platform)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "deployment_environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
        "query": "label_values(target_info{service_name=~\"tripbot|vlc-server\"}, deployment_environment)",
        "current": { "text": "prod-1", "value": "prod-1" },
        "includeAll": true,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Stream",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max by (deployment_environment, service_platform) (obs_streaming_active{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "[{{deployment_environment}} / {{service_platform}}]" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DARK", "color": "red" }, "1": { "text": "LIVE", "color": "green" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "OBS FPS (encoder)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max by (deployment_environment, service_platform) (obs_active_fps{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "[{{deployment_environment}} / {{service_platform}}]" }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1 }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Output bitrate",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "8 * max by (deployment_environment, service_platform) (rate(obs_stream_output_bytes{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]))", "legendFormat": "[{{deployment_environment}} / {{service_platform}}]" }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": { "defaults": { "unit": "bps" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Congestion",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max by (deployment_environment, service_platform) (obs_stream_output_congestion{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "[{{deployment_environment}} / {{service_platform}}]" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.25 },
            { "color": "red", "value": 0.5 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "VLC frame health (displayed vs lost)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "rate(vlc_player_displayed_pictures{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "displayed/s [{{deployment_environment}} / {{service_platform}}]" },
        { "refId": "B", "expr": "rate(vlc_player_lost_pictures{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "lost/s [{{deployment_environment}} / {{service_platform}}]" },
        { "refId": "C", "expr": "rate(vlc_player_demux_corrupted{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "demux corrupted/s [{{deployment_environment}} / {{service_platform}}]" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".* lost/s$" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byRegexp", "options": ".* demux corrupted/s$" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "OBS skipped frames",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "rate(obs_render_skipped_frames{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "render thread [{{deployment_environment}} / {{service_platform}}]" },
        { "refId": "B", "expr": "rate(obs_output_skipped_frames{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "output thread [{{deployment_environment}} / {{service_platform}}]" },
        { "refId": "C", "expr": "rate(obs_stream_output_skipped_frames{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "stream output [{{deployment_environment}} / {{service_platform}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Output bitrate",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "8 * rate(obs_stream_output_bytes{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "[{{deployment_environment}} / {{service_platform}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Congestion & reconnect state",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "max by (deployment_environment, service_platform) (obs_stream_output_congestion{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "congestion [{{deployment_environment}} / {{service_platform}}]" },
        { "refId": "B", "expr": "max by (deployment_environment, service_platform) (obs_stream_output_reconnecting{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "reconnecting [{{deployment_environment}} / {{service_platform}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "VLC input/demux bitrate (libvlc-native units)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "max by (deployment_environment, service_platform) (vlc_player_input_bitrate{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "input [{{deployment_environment}} / {{service_platform}}]" },
        { "refId": "B", "expr": "max by (deployment_environment, service_platform) (vlc_player_demux_bitrate{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "demux [{{deployment_environment}} / {{service_platform}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "OBS CPU & memory",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "max by (deployment_environment, service_platform) (obs_cpu_usage_percent{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "cpu % [{{deployment_environment}} / {{service_platform}}]" },
        { "refId": "B", "expr": "max by (deployment_environment, service_platform) (obs_memory_usage_mb{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "memory (MB) [{{deployment_environment}} / {{service_platform}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "OBS avg frame render time",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "max by (deployment_environment, service_platform) (obs_average_frame_render_time_ms{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "ms/frame [{{deployment_environment}} / {{service_platform}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Background audio (Twitch · SomaFM → Car Hum fallback)",
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "stat",
      "title": "Background audio",
      "description": "1 when the Twitch music bed (Groove Salad Classic) is playing, 0 when its OBS media state is ended/stopped/errored. Twitch-only (tripbot), not platform-labeled.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 28, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(obs_background_audio_playing{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "audio" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "mappings": [
            { "type": "value", "options": { "0": { "text": "SILENT", "color": "red" }, "1": { "text": "PLAYING", "color": "green" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 42,
      "type": "stat",
      "title": "Source",
      "description": "Which bed is on air: the normal SomaFM source, or the local Car Hum fallback the watchdog swaps in when SomaFM is unreachable.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 28, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(obs_background_audio_on_fallback{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "source" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 }
          ]},
          "mappings": [
            { "type": "value", "options": { "0": { "text": "SomaFM", "color": "green" }, "1": { "text": "CAR HUM (fallback)", "color": "yellow" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 43,
      "type": "stat",
      "title": "SomaFM edge",
      "description": "Result of the watchdog's last SomaFM edge probe (ice.somafm.com round-robin) — UP when an edge served stream bytes, DOWN when it timed out / sent nothing.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 28, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(somafm_reachable{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "somafm" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 44,
      "type": "stat",
      "title": "Source swaps (1h)",
      "description": "Background-audio source swaps in the last hour (to_fallback + to_somafm). Any to_fallback swap means SomaFM dropped.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 18, "y": 28, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(obs_background_audio_swaps_total{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[1h]))", "legendFormat": "swaps/1h" }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 45,
      "type": "timeseries",
      "title": "Background audio level (peak dBFS)",
      "description": "Peak output level of the Twitch background bed, floored at -60. Sustained ≈ -60 is dead air; recorded only while the volume meter is fresh, so gaps mean the meter subscription dropped (not silence).",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "min(obs_background_audio_level_db{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "peak dBFS" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 1, "min": -60, "max": 0,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": -50 }
          ]},
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 46,
      "type": "timeseries",
      "title": "Background audio state (playing / fallback / SomaFM reachable)",
      "description": "History of the three 0/1 signals driving the fallback. playing=0 is dead air; on fallback=1 means SomaFM has been down and we're on the local Car Hum bed.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "max(obs_background_audio_playing{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "playing" },
        { "refId": "B", "expr": "max(obs_background_audio_on_fallback{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "on fallback" },
        { "refId": "C", "expr": "max(somafm_reachable{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "somafm reachable" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "min": 0, "max": 1, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "on fallback" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "playing" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      }
    },
    {
      "id": 50,
      "type": "row",
      "title": "Decoder corruption (OBS-side, from decode logs)",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 1 }
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "OBS decode errors /s",
      "description": "Rate of H.264 decode errors in the OBS ffmpeg decoder (concealing, co-located POCs, MB-decode / cabac failures) — the decoder working on frames whose reference pictures are missing or mismatched. Spikes mean OBS is decoding across a clip splice without a clean reference reset. Baseline is near-zero on 3.17; a 10-20x jump was the gather (3.18) whole-frame block-corruption signature. Sourced from Loki (the errors exist only as decoder log lines, and prod is at the Prometheus active-series cap).",
      "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
      "gridPos": { "x": 0, "y": 41, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (pod) (rate({service_name=\"obs\", namespace=~\"$deployment_environment\", pod=~\"obs-($platform)-.*\"} |~ \"co located POCs unavailable|concealing [0-9]+ DC.*errors in [BP] frame|error while decoding MB|cabac decode of qscale diff failed\" [$__rate_interval]))", "legendFormat": "{{pod}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 2 }
          ]},
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 52,
      "type": "timeseries",
      "title": "Co-located POC failures (splice-specific)",
      "description": "count/interval of `co located POCs unavailable` — ffmpeg's error for a B-frame whose co-located reference picture is gone, i.e. decoding a clip boundary with no reference reset. The cleanest gather-vs-baseline discriminator: ~10 per 10min on 3.17, 80-200 per 10min under gather (3.18).",
      "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
      "gridPos": { "x": 12, "y": 41, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (pod) (count_over_time({service_name=\"obs\", namespace=~\"$deployment_environment\", pod=~\"obs-($platform)-.*\"} |~ \"co located POCs unavailable\" [$__interval]))", "legendFormat": "{{pod}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 40 } }, "overrides": [] }
    }
  ]
}
