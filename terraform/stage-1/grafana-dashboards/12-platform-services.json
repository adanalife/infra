{
  "title": "12 — Platform Services",
  "uid": "platform-services",
  "tags": ["platform", "external-dns", "cert-manager", "external-secrets", "cilium", "nats"],
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
        "query": "label_values(kube_pod_info, cluster)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "external-dns",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 101,
      "type": "stat",
      "title": "Registry endpoints (records in Route53)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(external_dns_registry_endpoints_per_zone{cluster=~\"$cluster\"})" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Source endpoints (Ingress targets)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(external_dns_source_endpoints_per_zone{cluster=~\"$cluster\"})" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Last reconcile",
      "description": "Seconds since the external-dns controller last reconciled. High = controller wedged.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "time() - max(external_dns_controller_last_reconcile_timestamp_seconds{cluster=~\"$cluster\"})" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red", "value": 600 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 104,
      "type": "stat",
      "title": "Errors (last 1h)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(external_dns_source_errors_total{cluster=~\"$cluster\"}[1h])) + sum(increase(external_dns_registry_errors_total{cluster=~\"$cluster\"}[1h]))" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 105,
      "type": "timeseries",
      "title": "Endpoints over time — source vs registry",
      "description": "Source = what Ingresses ask for. Registry = what Route53 currently has. Persistent gap = external-dns isn't keeping up.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "sum(external_dns_source_endpoints_per_zone{cluster=~\"$cluster\"})", "legendFormat": "source" },
        { "refId": "B", "expr": "sum(external_dns_registry_endpoints_per_zone{cluster=~\"$cluster\"})", "legendFormat": "registry" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 106,
      "type": "timeseries",
      "title": "Error rate (per minute)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(external_dns_source_errors_total{cluster=~\"$cluster\"}[5m])) * 60", "legendFormat": "source" },
        { "refId": "B", "expr": "sum(rate(external_dns_registry_errors_total{cluster=~\"$cluster\"}[5m])) * 60", "legendFormat": "registry" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },

    {
      "id": 200,
      "type": "row",
      "title": "cert-manager",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 }
    },
    {
      "id": 201,
      "type": "stat",
      "title": "Ready certificates",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 13, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(certmanager_certificate_ready_status{cluster=~\"$cluster\", condition=\"True\"})" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 202,
      "type": "stat",
      "title": "Not-ready certificates",
      "description": "Should be 0. A cert stuck not-ready usually means the issuer can't reach the ACME challenge target (DNS or HTTP).",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 13, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(certmanager_certificate_ready_status{cluster=~\"$cluster\", condition=\"False\"})" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 203,
      "type": "stat",
      "title": "Days until soonest expiry",
      "description": "Lowest certmanager_certificate_expiration_timestamp_seconds across all certs. LE auto-renews at 30 days remaining; alert if it dips below ~14.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 13, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "(min(certmanager_certificate_expiration_timestamp_seconds{cluster=~\"$cluster\"}) - time()) / 86400" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 14 },
              { "color": "green", "value": 30 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 204,
      "type": "stat",
      "title": "ACME errors (last 1h)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 18, "y": 13, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(certmanager_acme_client_request_count{cluster=~\"$cluster\", status!~\"2..\"}[1h]))" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 205,
      "type": "table",
      "title": "Per-certificate days-to-expiry",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "(certmanager_certificate_expiration_timestamp_seconds{cluster=~\"$cluster\"} - time()) / 86400", "format": "table", "instant": true }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "service": true, "endpoint": true, "container": true, "pod": true, "prometheus": true },
            "indexByName": {},
            "renameByName": { "name": "Certificate", "namespace": "Namespace", "issuer_name": "Issuer", "Value": "Days remaining" }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 14 },
              { "color": "green", "value": 30 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Days remaining" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "decimals", "value": 0 }
            ]
          }
        ]
      }
    },
    {
      "id": 206,
      "type": "timeseries",
      "title": "ACME request rate by status",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (status) (rate(certmanager_acme_client_request_count{cluster=~\"$cluster\"}[5m]))", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },

    {
      "id": 300,
      "type": "row",
      "title": "external-secrets",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 }
    },
    {
      "id": 301,
      "type": "stat",
      "title": "Sync success (last 1h)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 26, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(externalsecret_sync_calls_total{cluster=~\"$cluster\", status=\"success\"}[1h]))" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 302,
      "type": "stat",
      "title": "Sync errors (last 1h)",
      "description": "ESO sync failures — most often SM access denied (IAM) or a missing secret container.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 26, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(externalsecret_sync_calls_error{cluster=~\"$cluster\"}[1h]))" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 303,
      "type": "stat",
      "title": "ExternalSecrets ready",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 26, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(externalsecret_status_condition{cluster=~\"$cluster\", condition=\"Ready\", status=\"true\"})" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 304,
      "type": "stat",
      "title": "ClusterSecretStore ready",
      "description": "Should be 1 (the aws-secretsmanager store). 0 = ESO can't auth to AWS SM — check eso-aws-credentials Secret.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 18, "y": 26, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(clustersecretstore_status_condition{cluster=~\"$cluster\", condition=\"Ready\", status=\"true\"})" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 305,
      "type": "timeseries",
      "title": "Sync rate by status",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "sum by (status) (rate(externalsecret_sync_calls_total{cluster=~\"$cluster\"}[5m]))", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 400,
      "type": "row",
      "title": "cilium (datapath + agent)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 37, "w": 24, "h": 1 }
    },
    {
      "id": 401,
      "type": "stat",
      "title": "Endpoints ready",
      "description": "Cilium-managed endpoints in the ready state — roughly one per running pod on the node.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 38, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(cilium_endpoint_state{cluster=~\"$cluster\", endpoint_state=\"ready\"})" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 402,
      "type": "stat",
      "title": "Endpoints not ready",
      "description": "Endpoints stuck out of the ready state (waiting-for-identity, regenerating, etc.). Steady non-zero values point at identity/policy churn.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 38, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(cilium_endpoint_state{cluster=~\"$cluster\", endpoint_state!=\"ready\"})" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 403,
      "type": "stat",
      "title": "Policy import errors (last 1h)",
      "description": "Failed CiliumNetworkPolicy imports. Non-zero = a policy the agent couldn't compile/apply.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 38, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(cilium_policy_import_errors_total{cluster=~\"$cluster\"}[1h]))" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 404,
      "type": "stat",
      "title": "Packet drops (last 1h)",
      "description": "Datapath drops across all reasons. A baseline of policy-deny drops is normal; sudden spikes are the signal.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 18, "y": 38, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(cilium_drop_count_total{cluster=~\"$cluster\"}[1h]))" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 405,
      "type": "timeseries",
      "title": "Drop rate by reason",
      "description": "Datapath drops/sec broken down by reason — distinguishes expected policy denies from datapath errors (CT full, no route, etc.).",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 42, "w": 12, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "sum by (reason) (rate(cilium_drop_count_total{cluster=~\"$cluster\"}[5m]))", "legendFormat": "{{reason}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" }, "overrides": [] }
    },
    {
      "id": 406,
      "type": "timeseries",
      "title": "BPF map pressure",
      "description": "Per-map fill ratio (0–1). Approaching 1 means a BPF map is near capacity and entries may start getting evicted/rejected.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 42, "w": 12, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "max by (map_name) (cilium_bpf_map_pressure{cluster=~\"$cluster\"})", "legendFormat": "{{map_name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] }
    },
    {
      "id": 500,
      "type": "row",
      "title": "nats (message bus)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 49, "w": 24, "h": 1 }
    },
    {
      "id": 501,
      "type": "stat",
      "title": "Servers reporting",
      "description": "Count of NATS server instances currently emitting metrics. One per env namespace (stage-1-platform, prod-1-platform).",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 50, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "count(nats_varz_connections{cluster=~\"$cluster\"})" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 502,
      "type": "stat",
      "title": "Active connections",
      "description": "Open client connections aggregated across all NATS instances in the cluster.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 50, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(nats_varz_connections{cluster=~\"$cluster\"})" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 503,
      "type": "stat",
      "title": "Active subscriptions",
      "description": "Live subscriptions across all instances. Climbs as subscribers connect, drops on disconnect.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 50, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(nats_subsz_num_subscriptions{cluster=~\"$cluster\"})" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 504,
      "type": "stat",
      "title": "Slow consumers (last 1h)",
      "description": "Increase in slow-consumer count over the last hour. Non-zero means a subscriber couldn't keep up and got dropped — investigate the client.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 18, "y": 50, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(nats_varz_slow_consumers{cluster=~\"$cluster\"}[1h]))" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 505,
      "type": "timeseries",
      "title": "Message rate (in / out)",
      "description": "Per-second message throughput across all instances. Phase 0 is fire-and-forget pubsub; in == publishes received, out == subscriber deliveries.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 54, "w": 12, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(nats_varz_in_msgs{cluster=~\"$cluster\"}[5m]))", "legendFormat": "in" },
        { "refId": "B", "expr": "sum(rate(nats_varz_out_msgs{cluster=~\"$cluster\"}[5m]))", "legendFormat": "out" }
      ],
      "fieldConfig": { "defaults": { "unit": "mps" }, "overrides": [] }
    },
    {
      "id": 506,
      "type": "timeseries",
      "title": "Byte rate (in / out)",
