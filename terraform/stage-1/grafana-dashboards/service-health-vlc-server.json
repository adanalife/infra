{
  "title": "03 — Service Health: VLC Server",
  "uid": "vlc-server-service-health",
  "tags": ["tripbot", "vlc-server", "service-health"],
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "platform",
        "label": "Platform",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
        "query": "label_values(target_info{service_namespace=\"tripbot\"}, service_platform)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "deployment_environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
        "query": "label_values(target_info{service_name=\"vlc-server\"}, deployment_environment)",
        "current": { "text": "prod-1", "value": "prod-1" },
        "includeAll": true,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Data fresh (last 1m)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "(time() - max by (deployment_environment) (timestamp(last_over_time(http_server_request_duration_seconds_count{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[10m])))) < bool 60" , "legendFormat": "[{{deployment_environment}}]" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "mappings": [
            { "type": "value", "options": { "0": { "text": "STALE", "color": "red" }, "1": { "text": "FRESH", "color": "green" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests / sec",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum by (deployment_environment) (rate(http_server_request_duration_seconds_count{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[5m]))" , "legendFormat": "[{{deployment_environment}}]" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error rate (5xx)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum by (deployment_environment) (rate(http_server_request_duration_seconds_count{service_name=\"vlc-server\", service_platform=~\"$platform\", http_response_status_code=~\"5..\", deployment_environment=~\"$deployment_environment\"}[5m])) or vector(0)) / clamp_min(sum by (deployment_environment) (rate(http_server_request_duration_seconds_count{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[5m])), 0.001)"
        , "legendFormat": "[{{deployment_environment}}]" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 latency",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, deployment_environment) (rate(http_server_request_duration_seconds_bucket{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))" , "legendFormat": "[{{deployment_environment}}]" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP server latency (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le, deployment_environment) (rate(http_server_request_duration_seconds_bucket{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))", "legendFormat": "p50 [{{deployment_environment}}]" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le, deployment_environment) (rate(http_server_request_duration_seconds_bucket{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))", "legendFormat": "p95 [{{deployment_environment}}]" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le, deployment_environment) (rate(http_server_request_duration_seconds_bucket{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))", "legendFormat": "p99 [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests by status code",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (http_response_status_code, deployment_environment) (rate(http_server_request_duration_seconds_count{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]))", "legendFormat": "{{http_response_status_code}} [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 30, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Response size p95",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, deployment_environment) (rate(http_server_response_body_size_bytes_bucket{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))", "legendFormat": "p95 response [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Requests by method",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (http_request_method, deployment_environment) (rate(http_server_request_duration_seconds_count{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]))", "legendFormat": "{{http_request_method}} [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 30, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Recent errors & warnings",
      "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 10 },
      "targets": [
        { "refId": "A", "expr": "{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"} | service_platform=~\"$platform\" | detected_level=~\"error|warn\"" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Lost frames /s",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 30, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max by (deployment_environment) (rate(vlc_player_lost_pictures{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]))" , "legendFormat": "[{{deployment_environment}}]" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.1 },
            { "color": "red", "value": 1 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Demux discontinuity /s",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 30, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max by (deployment_environment) (rate(vlc_player_demux_discontinuity{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]))" , "legendFormat": "[{{deployment_environment}}]" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 2 }, "overrides": [] }
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Input bitrate (libvlc)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 18, "y": 30, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max by (deployment_environment) (vlc_player_input_bitrate{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"})" , "legendFormat": "[{{deployment_environment}}]" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 2 }, "overrides": [] }
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Playback stats over time",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "max by (deployment_environment) (vlc_player_displayed_fps{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "fps [{{deployment_environment}}]" },
        { "refId": "B", "expr": "rate(vlc_player_lost_pictures{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "lost/s [{{deployment_environment}}]" },
        { "refId": "C", "expr": "rate(vlc_player_demux_corrupted{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "demux corrupted/s [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 25,
      "type": "stat",
      "title": "HTTP panics (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "__DS_PROMETHEUS__"
      },
      "gridPos": {
        "x": 0,
        "y": 42,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (deployment_environment) (increase(tripbot_http_panics_total{service=\"vlc_server\", deployment_environment=~\"$deployment_environment\"}[1h]))"
        , "legendFormat": "[{{deployment_environment}}]" }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "Decoded video frames",
      "description": "Rate of decoded video blocks from libvlc. Pairs with displayed/lost — `decoded - displayed` exposes decode-but-don't-display loss.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 46, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "rate(vlc_player_decoded_video_frames{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "decoded/s [{{deployment_environment}}]" },
        { "refId": "B", "expr": "rate(vlc_player_displayed_pictures{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "displayed/s [{{deployment_environment}}]" },
        { "refId": "C", "expr": "rate(vlc_player_decoded_video_frames{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]) - rate(vlc_player_displayed_pictures{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "decoded - displayed [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "OBS render skip ratio",
      "description": "Fraction of render-thread frames OBS skipped. Climbing means the render thread is falling behind compositing — check OBS CPU / scene complexity.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 46, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "rate(obs_render_skipped_frames{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]) / clamp_min(rate(obs_render_total_frames{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]), 0.001)", "legendFormat": "render skip ratio [{{deployment_environment}}]" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "OBS output skip ratio",
      "description": "Fraction of output frames OBS dropped before encode. Climbing means the encoder pipeline is falling behind — check encoder preset / CPU.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 54, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "rate(obs_output_skipped_frames{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]) / clamp_min(rate(obs_output_total_frames{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]), 0.001)", "legendFormat": "output skip ratio [{{deployment_environment}}]" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 43,
      "type": "timeseries",
      "title": "OBS stream skip ratio",
      "description": "Fraction of stream-output frames OBS dropped due to network/encoder congestion. Climbing means upstream bandwidth or Twitch ingest is constrained.",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 54, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "rate(obs_stream_output_skipped_frames{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]) / clamp_min(rate(obs_stream_output_total_frames{service_name=\"vlc-server\", service_platform=~\"$platform\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]), 0.001)", "legendFormat": "stream skip ratio [{{deployment_environment}}]" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]}
        },
        "overrides": []
      }
    }
  ]
}
