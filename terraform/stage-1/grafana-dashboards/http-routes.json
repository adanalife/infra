{
  "title": "11 — HTTP Routes",
  "uid": "http-routes",
  "tags": ["tripbot", "vlc-server", "http"],
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "deployment_environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
        "query": "label_values(target_info, deployment_environment)",
        "current": { "text": "prod-1", "value": "prod-1" },
        "includeAll": true,
        "multi": false,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
        "query": "label_values(http_server_request_duration_seconds_count, service_name)",
        "current": { "text": "tripbot", "value": "tripbot" },
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 0,
      "type": "text",
      "title": "Why method, not route?",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "Tables and breakdowns group by **`http_request_method`** (not `http_route`) because otelhttp's middleware doesn't know route templates without help from the framework. Negroni doesn't expose the matched route, so `http_route` is empty for every request and the table collapses to one row. Once `otelhttp.WithRouteTag` is wired per route registration in tripbot's `pkg/server` + `pkg/vlc-server`, swap method → route here."
      }
    },
    {
      "id": 1,
      "type": "table",
      "title": "Top methods — RPS / p95 / p99 / error rate",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 3, "w": 24, "h": 9 },
      "transformations": [
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "RPS",
              "Value #B": "p95 latency",
              "Value #C": "p99 latency",
              "Value #D": "error rate"
            },
            "indexByName": {},
            "excludeByName": { "Time": true, "service_name": true, "__name__": true, "job": true, "instance": true }
          }
        }
      ],
      "targets": [
        { "refId": "A", "format": "table", "instant": true, "expr": "sum by (http_request_method) (rate(http_server_request_duration_seconds_count{service_name=\"$service\", deployment_environment=~\"$deployment_environment\"}[5m]))" },
        { "refId": "B", "format": "table", "instant": true, "expr": "histogram_quantile(0.95, sum by (le, http_request_method) (rate(http_server_request_duration_seconds_bucket{service_name=\"$service\", deployment_environment=~\"$deployment_environment\"}[5m])))" },
        { "refId": "C", "format": "table", "instant": true, "expr": "histogram_quantile(0.99, sum by (le, http_request_method) (rate(http_server_request_duration_seconds_bucket{service_name=\"$service\", deployment_environment=~\"$deployment_environment\"}[5m])))" },
        { "refId": "D", "format": "table", "instant": true, "expr": "(sum by (http_request_method) (rate(http_server_request_duration_seconds_count{service_name=\"$service\", deployment_environment=~\"$deployment_environment\", http_response_status_code=~\"5..\"}[5m])) or sum by (http_request_method) (rate(http_server_request_duration_seconds_count{service_name=\"$service\", deployment_environment=~\"$deployment_environment\"}[5m]) * 0)) / clamp_min(sum by (http_request_method) (rate(http_server_request_duration_seconds_count{service_name=\"$service\", deployment_environment=~\"$deployment_environment\"}[5m])), 0.001)" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "RPS" }, "properties": [ { "id": "unit", "value": "reqps" } ] },
          { "matcher": { "id": "byName", "options": "p95 latency" }, "properties": [ { "id": "unit", "value": "s" } ] },
          { "matcher": { "id": "byName", "options": "p99 latency" }, "properties": [ { "id": "unit", "value": "s" } ] },
          { "matcher": { "id": "byName", "options": "error rate" }, "properties": [ { "id": "unit", "value": "percentunit" } ] }
        ]
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests by status code",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 9 },
      "targets": [
        { "refId": "A", "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_seconds_count{service_name=\"$service\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]))", "legendFormat": "{{http_response_status_code}} [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requests by method",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 9 },
      "targets": [
        { "refId": "A", "expr": "sum by (http_request_method) (rate(http_server_request_duration_seconds_count{service_name=\"$service\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]))", "legendFormat": "{{http_request_method}} [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "heatmap",
      "title": "Request latency heatmap",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 10 },
      "targets": [
        { "refId": "A", "format": "heatmap", "expr": "sum by (le) (rate(http_server_request_duration_seconds_bucket{service_name=\"$service\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval]))", "legendFormat": "{{le}}" }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Spectral", "mode": "scheme" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request body size (p95)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, http_request_method) (rate(http_server_request_body_size_bytes_bucket{service_name=\"$service\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))", "legendFormat": "{{http_request_method}} [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Response body size (p95)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, http_request_method) (rate(http_server_response_body_size_bytes_bucket{service_name=\"$service\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))", "legendFormat": "{{http_request_method}} [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] }
    }
  ]
}
