{
  "title": "08 — Postgres Pool",
  "uid": "postgres-pool",
  "tags": ["tripbot", "postgres", "database"],
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Open connections",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(db_sql_connection_open{service_name=\"tripbot\"})" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Max open",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(db_sql_connection_max_open{service_name=\"tripbot\"})" }
      ],
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Connection waits / 5m",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "increase(db_sql_connection_wait_total{service_name=\"tripbot\"}[5m])" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 50 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Query errors / 5m",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(increase(db_sql_latency_milliseconds_count{service_name=\"tripbot\", status=\"error\"}[5m]))" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 10 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Connection pool by status",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "db_sql_connection_open{service_name=\"tripbot\"}", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 30, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Wait duration",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "rate(db_sql_connection_wait_duration_milliseconds_total{service_name=\"tripbot\"}[5m])", "legendFormat": "avg wait ms/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Query latency p95 by method",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 9 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, method) (rate(db_sql_latency_milliseconds_bucket{service_name=\"tripbot\", status=\"ok\"}[5m])))", "legendFormat": "{{method}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Query rate by method (ok vs error)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 9 },
      "targets": [
        { "refId": "A", "expr": "sum by (method, status) (rate(db_sql_latency_milliseconds_count{service_name=\"tripbot\"}[5m]))", "legendFormat": "{{method}} / {{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] }
    }
  ]
}
