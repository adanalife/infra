{
  "title": "00 — Launch / Stream at a Glance",
  "uid": "stream-at-a-glance",
  "tags": ["tripbot", "vlc-server", "obs", "stream", "launch"],
  "schemaVersion": 39,
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "links": [
    {
      "title": "Verification runbook",
      "type": "link",
      "icon": "doc",
      "url": "https://github.com/adanalife/vault/blob/main/twitch/live-stream-verification.md",
      "targetBlank": true,
      "tooltip": "How to read this dashboard — the live-stream verification runbook"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "deployment_environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
        "query": "label_values(target_info{service_name=~\"tripbot|vlc-server\"}, deployment_environment)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": false,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "twitch_channel",
        "label": "Twitch channel",
        "type": "custom",
        "description": "Which Twitch channel the Live-stream panel embeds. Pair with deployment_environment: stage-1 → adanalife_staging, prod-1 → adanalife_.",
        "query": "stage-1 : adanalife_staging, prod-1 : adanalife_",
        "current": { "text": "stage-1", "value": "adanalife_staging", "selected": true },
        "options": [
          { "text": "stage-1", "value": "adanalife_staging", "selected": true },
          { "text": "prod-1", "value": "adanalife_", "selected": false }
        ],
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Stream",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(obs_streaming_active{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"})" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DARK", "color": "red" }, "1": { "text": "LIVE", "color": "green" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "OBS FPS (encoder)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(obs_active_fps{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"})" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1 }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Output bitrate",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "8 * rate(obs_stream_output_bytes{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[1m])" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "bps" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "OBS CPU",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "description": "OBS process CPU. Healthy ~55% post-VAAPI. Climbing into the hundreds means the encoder fell back to x264.",
      "targets": [
        { "refId": "A", "expr": "max(obs_cpu_usage_percent{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"})" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 300 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Congestion",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(obs_stream_output_congestion{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"})" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.25 },
            { "color": "red", "value": 0.5 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Bot data fresh (last 1m)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 4, "w": 4, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "(time() - max(timestamp(last_over_time(http_server_request_duration_seconds_count{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[10m])))) < bool 60" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]},
          "mappings": [
            { "type": "value", "options": { "0": { "text": "STALE", "color": "red" }, "1": { "text": "FRESH", "color": "green" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Bot error rate (5xx)",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 4, "y": 4, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "(sum(rate(http_server_request_duration_seconds_count{service_name=\"tripbot\", http_response_status_code=~\"5..\", deployment_environment=~\"$deployment_environment\"}[5m])) or vector(0)) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[5m])), 0.001)" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]}
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Subscribers",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 9, "y": 4, "w": 5, "h": 4 },
      "description": "Populated via the broadcaster-token Helix path. Zero here points at the broadcaster token, not the stream.",
      "targets": [
        { "refId": "A", "expr": "max(twitch_subscribers_total{service_name=\"tripbot\"})" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Messages / min",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 14, "y": 4, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(tripbot_chat_messages_total{service_name=\"tripbot\"}[5m])) * 60" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1 }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "DB pool in-use",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 19, "y": 4, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(db_sql_connection_open{service_name=\"tripbot\", status=\"inuse\"})" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Output bitrate",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "8 * rate(obs_stream_output_bytes{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "stream output" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "OBS CPU & frame health",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "max(obs_cpu_usage_percent{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"})", "legendFormat": "cpu %" },
        { "refId": "B", "expr": "rate(obs_render_skipped_frames{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "render skipped/s" },
        { "refId": "C", "expr": "rate(obs_output_skipped_frames{service_name=\"vlc-server\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])", "legendFormat": "output skipped/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "render skipped/s" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "output skipped/s" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "id": 30,
      "type": "logs",
      "title": "Recent errors & warnings (tripbot + vlc-server)",
      "datasource": { "type": "loki", "uid": "__DS_LOKI__" },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 9 },
      "targets": [
        { "refId": "A", "expr": "{service_name=~\"tripbot|vlc-server\"} | detected_level=~\"error|warn\"" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Descending" }
    },
    {
      "id": 40,
      "type": "text",
      "title": "Live stream (${twitch_channel})",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 9 },
      "options": {
        "mode": "html",
        "content": "<iframe src=\"https://player.twitch.tv/?channel=${twitch_channel}&parent=adanalife.grafana.net&muted=true\" width=\"100%\" height=\"100%\" frameborder=\"0\" allowfullscreen=\"true\"></iframe>"
      }
    }
  ]
}
