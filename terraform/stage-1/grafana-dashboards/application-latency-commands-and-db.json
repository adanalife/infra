      "type": "table",
      "title": "DB operations — rate / p50 / p95 / p99",
      "datasource": { "type": "prometheus", "uid": "__DS_PROMETHEUS__" },
      "gridPos": { "x": 0, "y": 47, "w": 24, "h": 9 },
      "transformations": [
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "rate /s",
              "Value #B": "p50",
              "Value #C": "p95",
              "Value #D": "p99"
            },
            "indexByName": {},
