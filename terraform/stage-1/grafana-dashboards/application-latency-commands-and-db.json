      "targets": [
        { "refId": "A", "expr": "sum by (error_type, deployment_environment) (rate(db_client_operation_duration_seconds_count{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\", error_type!=\"\"}[$__rate_interval]))", "legendFormat": "{{error_type}} [{{deployment_environment}}]" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] }
