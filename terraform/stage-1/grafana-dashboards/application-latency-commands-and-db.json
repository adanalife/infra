      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, deployment_environment) (rate(db_client_operation_duration_seconds_bucket{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[5m])))" , "legendFormat": "[{{deployment_environment}}]" }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
