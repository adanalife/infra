        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le, deployment_environment) (rate(db_client_operation_duration_seconds_bucket{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))", "legendFormat": "p95 [{{deployment_environment}}]" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le, deployment_environment) (rate(db_client_operation_duration_seconds_bucket{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[$__rate_interval])))", "legendFormat": "p99 [{{deployment_environment}}]" }
