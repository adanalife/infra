        }
      ],
      "targets": [
        { "refId": "A", "format": "table", "instant": true, "expr": "sum by (db_operation_name, deployment_environment) (rate(db_client_operation_duration_seconds_count{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[5m]))" },
        { "refId": "B", "format": "table", "instant": true, "expr": "histogram_quantile(0.50, sum by (le, db_operation_name, deployment_environment) (rate(db_client_operation_duration_seconds_bucket{service_name=\"tripbot\", deployment_environment=~\"$deployment_environment\"}[5m])))" },
