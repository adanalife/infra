# Per-machine override generated by `task k8s:prod:bootstrap-secrets`. Holds
# the minipc's LAN IP — discovered from the node's InternalIP
# (`kubectl get nodes -o jsonpath='{.items[0].status.addresses[?(@.type=="InternalIP")].address}'`),
# or EXTERNAL_DNS_TARGET_IP if set — and feeds it to traefik as
# providers.kubernetesIngress.ingressEndpoint.ip.
#
# Traefik stamps this IP into every managed Ingress's status.loadBalancer, so
# external-dns can publish a Route53 target without a per-Ingress
# external-dns.alpha.kubernetes.io/target annotation (there's no LoadBalancer
# controller on bare-metal Talos to fill the Service's EXTERNAL-IP, which is
# what the base values.yml `publishedService` would otherwise copy from).
#
# Layered onto values.yml + values.prod-1.yml at helm-install time. Keeps the
# host-specific IP out of git. Delete + re-run bootstrap-secrets to regenerate.
providers:
  kubernetesIngress:
    ingressEndpoint:
      ip: 192.168.1.200
