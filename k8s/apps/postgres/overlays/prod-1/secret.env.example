# Copy this file to `secret.env` and fill in values that match tripbot's
# expected DATABASE_* connection vars for prod-1. The actual secret.env
# is gitignored.
#
# Pick a strong unique password. Once postgres is up and you've
# restored the existing dump, these values must continue to match
# tripbot's expectations — if you're restoring from a dump that
# already has a `tripbot` user defined, the password here needs to
# match what's in that dump (or be updated post-restore via
# `ALTER USER tripbot WITH PASSWORD '...';`).
#
# TODO: promote this to an ESO ExternalSecret reading from a
# k8s/postgres/credentials SM container, so the credential doesn't
# live in a gitignored file on a single machine.
POSTGRES_USER=tripbot
POSTGRES_PASSWORD=replace-me-with-strong-password
POSTGRES_DB=tripbot
