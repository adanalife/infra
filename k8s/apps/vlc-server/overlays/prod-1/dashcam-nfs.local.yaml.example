# Template for the static NFS PV + PVC backing vlc-server's dashcam
# corpus. Copy to dashcam-nfs.local.yaml (gitignored) and fill in the
# server address + share path for this cluster's NFS source.
#
# The PV is bound to the PVC explicitly via volumeName +
# storageClassName: "" so no dynamic provisioning is involved.
# capacity is a placeholder — NFS doesn't enforce it.
apiVersion: v1
kind: PersistentVolume
metadata:
  name: vlc-dashcam-nfs
spec:
  capacity:
    storage: 1Ti
  accessModes:
    - ReadOnlyMany
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  nfs:
    server: <NFS server address>
    path: <export path>
    readOnly: true
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: vlc-dashcam
spec:
  accessModes:
    - ReadOnlyMany
  storageClassName: ""
  volumeName: vlc-dashcam-nfs
  resources:
    requests:
      storage: 1Ti
