# Template for the static NFS PV + PVC backing stage-1 vlc-server's
# dashcam corpus. Copy to dashcam-nfs.local.yaml (gitignored) and fill in
# the server address + share path.
#
# Stage SHARES prod's NFS export read-only — there is no second copy of
# the corpus. Because a PV binds 1:1 to a PVC, stage needs its OWN PV
# (vlc-dashcam-nfs-stage, distinct from prod's vlc-dashcam-nfs) pointing
# at the SAME server/path. Both are ReadOnlyMany, so the NFS server
# serves prod and stage concurrently.
#
# The PV is bound to the PVC explicitly via volumeName + storageClassName:
# "" so no dynamic provisioning is involved. capacity is a placeholder —
# NFS doesn't enforce it.
apiVersion: v1
kind: PersistentVolume
metadata:
  name: vlc-dashcam-nfs-stage
spec:
  capacity:
    storage: 1Ti
  accessModes:
    - ReadOnlyMany
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ""
  nfs:
    server: <NFS server address>
    path: <export path>
    readOnly: true
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: vlc-dashcam
spec:
  accessModes:
    - ReadOnlyMany
  storageClassName: ""
  volumeName: vlc-dashcam-nfs-stage
  resources:
    requests:
      storage: 1Ti
