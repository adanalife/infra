# Copy this file to `secret.env` and fill in values from
# tripbot/.env.development. Empty/stub values are fine for fields
# whose features you aren't exercising locally.
DATABASE_USER=tripbot_docker
DATABASE_PASS=hunter2
DATABASE_DB=tripbot_docker

# Twitch identity. Stubs are fine here — in stage-1 / prod-1 clusters
# ESO overrides TWITCH_CLIENT_ID + TWITCH_CLIENT_SECRET with the real
# values from AWS Secrets Manager (k8s/tripbot/twitch-creds). The IRC
# token isn't an env var anymore — it lives in the oauth_tokens DB
# table, populated by `task auth:bootstrap` on first run.
CHANNEL_NAME=adanalife
BOT_USERNAME=tripbot4000
TWITCH_CLIENT_ID=stub
TWITCH_CLIENT_SECRET=stub

# GOOGLE_MAPS_API_KEY is overridden by ESO in stage-1 / prod-1 from
# k8s/tripbot/google-maps-api-key — `stub` here just gets the bot past
# the required-env check on boot.
GOOGLE_MAPS_API_KEY=stub

TWILIO_ACCT_SID=stub
TWILIO_AUTH_TOKEN=stub
TWILIO_FROM_NUM=+15555550100
TWILIO_TO_NUM=+15555550101

SENTRY_DSN=
# SENTRY_ENVIRONMENT defaults to "stage" via the local overlay's configMap
# (overridden to "production" by the prod-1 overlay). Uncomment + set here
# only if you specifically want this machine's events to land under a
# different env tag — k8s envFrom is last-wins, so a secret value here
# would override the configMap default.
# SENTRY_ENVIRONMENT=local

EXTERNAL_URL=http://tripbot.localhost
