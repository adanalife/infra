# Optional per-machine override for k3d-config.bees.yaml. Copy this file
# to `k3d-config.bees.local.yaml` (gitignored) and fill in the host-specific
# NAS bind-mount path. The `k8s:stage:cluster:up` task prefers this file
# over the committed `k3d-config.bees.yaml` when it exists.
#
# This file must be a full superset of `k3d-config.bees.yaml` — k3d
# doesn't merge config files. The only intended difference is the
# additional `/host/nas-dashcam` volume entry used by the stage-1-nas
# overlay (vlc-server reads dashcam footage from a host-mounted NAS share).
#
# Mount path must be a directory the cluster host's user can read. The
# `:ro` suffix enforces read-only at the Docker bind level so the k3d
# node itself cannot write to the NAS.
apiVersion: k3d.io/v1alpha5
kind: Simple
metadata:
  name: adanalife-bees

servers: 1
agents: 0

volumes:
  - volume: /Users/dmerrick/adanalife/tripbot/assets/video:/host/dashcam
    nodeFilters:
      - server:*
  # Replace `/path/to/your/nas/dashcam` with the host-local mount point
  # of the NAS share that holds your dashcam footage.
  - volume: "/path/to/your/nas/dashcam:/host/nas-dashcam:ro"
    nodeFilters:
      - server:*

options:
  k3s:
    extraArgs:
      - arg: --disable=traefik
        nodeFilters:
          - server:*

ports:
  - port: 9080:80
    nodeFilters:
      - loadbalancer
  - port: 9443:443
    nodeFilters:
      - loadbalancer
