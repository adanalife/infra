# Per-machine override generated by `task k8s:stage:bootstrap-secrets`.
# Feeds external-dns `--default-targets` so any Ingress without an
# explicit external-dns.alpha.kubernetes.io/target annotation resolves to
# the mini-PC's LAN IP. Kept out of git (the real values.local.yml is
# gitignored).
#
# adanalife-minipc is LAN-only by design, so the default target is the
# node's LAN IP (192.168.1.200, pinned by router DHCP reservation), not a
# public IP. Override with EXTERNAL_DNS_TARGET_IP=<ip>.
#
# --force-default-targets is required because traefik writes the
# cluster-internal LB IP into Ingress.status, and external-dns prefers
# source-provided targets unless told to override them.
extraArgs:
  - --default-targets=192.168.1.200
  - --force-default-targets
