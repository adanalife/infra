# Per-machine override generated by `task k8s:bootstrap-secrets`. Holds
# the host's current public IP (via `curl ifconfig.me`) and feeds it to
# external-dns as `--default-targets`, so Ingresses that don't specify
# their own `external-dns.alpha.kubernetes.io/target` annotation get
# this machine's IP automatically. Keeps the IP out of git.
#
# Re-run `task k8s:bootstrap-secrets` if your home IP rotates.
extraArgs:
  - --default-targets=0.0.0.0
