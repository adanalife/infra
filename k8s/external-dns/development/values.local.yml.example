# Per-machine override generated by `task k8s:dev:bootstrap-secrets`. Holds
# the host's current public IPv4 (via `curl -4 ifconfig.me`) and feeds
# it to external-dns as `--default-targets`, so Ingresses that don't
# specify their own `external-dns.alpha.kubernetes.io/target` annotation
# get this machine's IP automatically. Keeps the IP out of git.
#
# --force-default-targets is required because traefik writes the
# cluster-internal klipper-lb IP into Ingress.status, and external-dns
# prefers source-provided targets unless told to override them with
# the default.
#
# Re-run `task k8s:dev:bootstrap-secrets` if your home IP rotates.
extraArgs:
  - --default-targets=0.0.0.0
  - --force-default-targets
