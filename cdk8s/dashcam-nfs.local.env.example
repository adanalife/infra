# Host-specific dashcam NFS coordinates for `task k8s:<env>:dashcam-pv`.
#
# Copy to `dashcam-nfs.local.env` (gitignored) and fill in your NAS export.
# The task sources these and synths the cluster-scoped dashcam PersistentVolume
# with them, applying it OUTSIDE Argo (the committed dist/ carries placeholders,
# so no host specifics live in git). stage and prod share the same read-only
# export — one file serves both; the per-env PV name differs (config.py).
NFS_SERVER=<NFS server address>
NFS_PATH=<export path>
